# Etapa 1 - Build com Maven
FROM maven:3.9.6-eclipse-temurin-21 AS build
WORKDIR /app
COPY pom.xml ./
RUN mvn dependency:go-offline -B
COPY src ./src
RUN mvn clean install -DskipTests

# Etapa 2 - Runtime
FROM eclipse-temurin:21-jre-jammy
WORKDIR /app
COPY --from=build /app/target/*.jar suricato-backend-app.jar
EXPOSE 8080
CMD ["java", "-jar", "suricato-backend-app.jar"]